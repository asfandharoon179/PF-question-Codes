#include<iostream>
using namespace std;
int main() {
	int arr1[5];
	cout << "Enter the elements of the array please\n";
	for (int i = 0; i < 5; i++) {
		cin >> arr1[i];
	}
	int max = arr1[0];
	for (int y = 0; y < 5; y++)
	{
		if (arr1[y] > max)
		    {
			max = arr1[y];
			}
     } 
	cout << "The max digit is " << max<< endl;
	return 0;
	}



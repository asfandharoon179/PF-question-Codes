#include<iostream>
using namespace std;
int main() {
	char ch;
	cout << "Enter your Character\n";
	cin >> ch;
	int ascii = ch;
	if (ascii >= 65 && ascii <= 90) {
		cout << "It is an UpperCase  Character";
	}
	else if (ascii >= 97 && ascii <= 122) {
		cout << "It is  a lower case Character";
	}
	else if (ch >= 0 && ch <= 1000) {
		cout << "It is an Integer";
	}
	else {
		cout << "It is an Integer";
	}
	return 0;
}
